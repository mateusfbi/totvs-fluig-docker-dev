# Configuração de Fuso Horário dos contêineres
TZ=America/Sao_Paulo

# Flags para habilitar/desabilitar a instalação de serviços adicionais
INSTALL_NODE=false
INSTALL_SOLR=false

# Configurações de inicialização e credenciais do contêiner MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=fluig
MYSQL_USER=fluig
MYSQL_PASSWORD=fluig

# Parâmetros de conexão que o Fluig utilizará para se conectar ao MySQL
FLUIG_DB_HOST=mysql
FLUIG_DB_PORT=3306
FLUIG_DB_NAME=fluig
FLUIG_DB_USER=fluig
FLUIG_DB_PASS=fluig

# Configurações de memória da JVM do Fluig (Memória Inicial e Máxima)
JAVA_XMS=2g
JAVA_XMX=4g
